config telegram 'bot'
	option enabled '0'
	option api_token ''
	option poll_interval '2'
	option poll_timeout '30'
	option curl_connect_timeout '10'
	option curl_max_time '30'
	option log_level 'info'
	option check_updates_interval '86400'
	option language 'en'
	option rate_limit_count '10'
	option rate_limit_window '3'
	option log_bot_max_lines '1000'
	option log_bot_reset_time '86400'
	option log_auth_max_lines '1000'
	option log_auth_reset_time '86400'

config telegram 'admins'
	list admin_id ''

config telegram 'notifications'
	option new_device '0'
	option wan_ip_change '0'
	option high_cpu '0'
	option high_cpu_threshold '90'
	option high_ram '0'
	option high_ram_threshold '90'
	option update_available '0'
